    "schema_version": 1,
    "fragment_size": 1300,
    "required_sections": [
      "fragment_reassembly",
      "queued_followup"
    ],
    "fragment_checks": [
      "capture_id is present",
      "fragmentStart equals the previous accumulated length for that sequence",
      "accumulatedLength equals fragmentStart plus fragmentLength",
      "at least one full FRAGMENT_SIZE fragment is present and not accepted",
      "at least one terminal short fragment is present and accepted",
      "terminal short fragments carry a lowercase SHA-256 reassembledPayloadHash"
    ],
    "queued_followup_checks": [
      "at least one queued follow-up event is present",
      "queuedMessageSequence is present",
      "storedEncoded is false",
      "encodedOnPop is true",
      "datagramHash is a lowercase SHA-256 hex string",
      "the final queued follow-up event has queueEmptyAfterPop true"
    ],
    "retail_provenance_required_for_closure": true
  },
  "report_columns": [
    "sequence",
    "fragmentStart",
    "fragmentLength",
    "accumulatedLength",
    "accepted",
    "reassembledPayloadHash",
    "queuedMessageSequence",
    "storedEncoded",
    "encodedOnPop",
    "queueEmptyAfterPop",
    "datagramHash"
  ],
