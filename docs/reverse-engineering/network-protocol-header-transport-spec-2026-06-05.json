  "packet_headers": [
    {
      "id": "connectionless_oob",
      "description": "Generic out-of-band control packet.",
      "direction": "both",
      "relative_to": "datagram start",
      "fields": [
        {
          "name": "sentinel",
          "offset": 0,
          "bytes": 4,
          "value": "0xffffffff"
        },
        {
          "name": "command_or_payload",
          "offset": 4,
          "bytes": "variable",
          "encoding": "raw bytes unless this is the profile-gated compressed connect exception"
        }
      ],
      "source_anchors": [
        "NET_OutOfBandPrint",
        "NET_OutOfBandRaw",
        "SV_ConnectionlessPacket"
      ]
    },
    {
      "id": "compressed_connect_oob",
      "description": "Profile-gated connect request sent through NET_OutOfBandData.",
      "direction": "client-to-server",
      "relative_to": "datagram start",
      "fields": [
        {
          "name": "sentinel",
          "offset": 0,
          "bytes": 4,
          "value": "0xffffffff"
        },
        {
          "name": "clear_connect_token",
          "offset": 4,
          "bytes": 7,
          "value": "connect"
        },
        {
          "name": "clear_delimiter",
          "offset": 11,
          "bytes": 1,
          "value": "space"
        },
        {
          "name": "compressed_remainder",
          "offset": 12,
          "bytes": "variable",
          "value": "quoted userinfo and trailing Huffman-compressed bytes"
        }
      ],
      "compression": {
        "client_compress_function": "Huff_Compress",
        "client_compress_offset": 12,
        "server_decompress_function": "Huff_Decompress",
        "server_decompress_offset": 12,
        "packet_detector": "NET_IsConnectRequestPacket",
        "detector_command_offset": 4,
        "accepted_detectors_after_token": [
          "nul",
          "space",
          "double_quote",
          "line_feed",
          "carriage_return"
        ]
      }
    },
    {
      "id": "client_netchan_unfragmented",
      "description": "Sequenced client packet without fragmentation.",
      "direction": "client-to-server",
      "relative_to": "datagram start",
      "fields": [
        {
          "name": "sequence",
          "offset": 0,
          "bytes": 4
        },
        {
