        {
          "name": "client_message_body",
          "offset": 6,
          "bytes": "variable"
        }
      ]
    },
    {
      "id": "server_netchan_unfragmented",
      "description": "Sequenced server packet without fragmentation.",
      "direction": "server-to-client",
      "relative_to": "datagram start",
      "fields": [
        {
          "name": "sequence",
          "offset": 0,
          "bytes": 4
